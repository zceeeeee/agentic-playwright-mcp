# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Browser engine: "true" = CloakBrowser stealth (default), "false" = Playwright
# USE_CLOAKBROWSER=true

# Headless mode: "true" = no visible window, "false" = headed (default)
# BROWSER_HEADLESS=false

# Playwright browser download host (optional, for China mirror)
# PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# Vision model API key (for visual verification in test cycles)
# VISION_API_KEY=your-vision-api-key-here

# LLM Fallback（规则无法解析自然语言时，用 LLM 兜底）
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Logging configuration
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO

# LOG_FORMAT: "json" for structured logs, "text" for human-readable (default: text)
# LOG_FORMAT=text
