# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Provider: "openai" (default) | "anthropic"
# LLM_PROVIDER=openai

# Browser engine: "true" = CloakBrowser stealth (default), "false" = Playwright
# USE_CLOAKBROWSER=true

# Browser engine: cloakbrowser | playwright | local_chrome
# BROWSER_ENGINE=cloakbrowser

# Local Chrome mode uses your installed Chrome with a persistent FeatherDesk
# profile. Leave the path and profile empty to use automatic defaults.
# LOCAL_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# LOCAL_CHROME_DEBUG_PORT=9222
# LOCAL_CHROME_USER_DATA=
# LOCAL_CHROME_AUTO_LAUNCH=true

# Headless mode: "true" = no visible window, "false" = headed (default)
# BROWSER_HEADLESS=false

# Playwright browser download host (optional, for China mirror)
# PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# Vision model API key (for visual verification in test cycles)
# VISION_API_KEY=your-vision-api-key-here

# LLM Fallback（规则无法解析自然语言时，用 LLM 兜底）
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic（当 LLM_PROVIDER=anthropic 时生效）
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# LLM 通用参数
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=1024
# LLM_TIMEOUT=30

# Logging configuration
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO

# LOG_FORMAT: "json" for structured logs, "text" for human-readable (default: text)
# LOG_FORMAT=text

# Explore mode deep scan config
# EXPLORE_MIN_INTERACTIVE_THRESHOLD=5
# EXPLORE_DEEP_SCAN_MAX_ELEMENTS=150

# LLM thinking mode (enable_thinking for Qwen/local models)
# LLM_THINKING_ENABLED=true
